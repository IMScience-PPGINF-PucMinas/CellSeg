# Main pipeline (2026): gradvmaxmul + minsc, sigmoid saliency, SICLE raw (no morph / no AUR)
SICLE_CONN=gradvmaxmul
SICLE_CRIT=minsc
SICLE_ALPHA=2.0
SICLE_NF=2
SICLE_N0=200
SICLE_IRREG=0
SICLE_ADHR=1
SICLE_MAX_ITERS=7
SALIENCY_LINEARIZE=0
SALIENCY_THRESHOLD=0.3
SALIENCY_BLUR_SIGMA=0.5
MARGIN=4
MIN_CELL_AREA=128
# Post-process: SICLE raw in bbox only
DISABLE_AND_MERGE=1
CLOSING_RADIUS=0
